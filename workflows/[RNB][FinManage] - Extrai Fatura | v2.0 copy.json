      "parameters": {
        "jsCode": "// toolWorkflow envolve parâmetros em { query: { ... } }\n// Suporta ambos os formatos: raiz direta OU aninhado em query\nconst raw = $input.first().json;\nconst item = (raw.fileURL || raw.usuario_id) ? raw : (raw.query || raw);\n\nconst erros = [];\n\nif (!item.fileURL || String(item.fileURL).trim() === '') {\n  erros.push('Parâmetro obrigatório ausente: fileURL');\n}\nif (!item.usuario_id || String(item.usuario_id).trim() === '') {\n  erros.push('Parâmetro obrigatório ausente: usuario_id');\n}\n\nif (erros.length > 0) {\n  return [{ json: { inputs_validos: false, erros, fileURL: item.fileURL || '', usuario_id: item.usuario_id || '' } }];\n}\n\nreturn [{ json: { inputs_validos: true, erros: [], fileURL: item.fileURL, usuario_id: item.usuario_id } }];"
      },
