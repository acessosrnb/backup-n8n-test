    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst usuario_id = $('valida_inputs').first().json.usuario_id;\nconst fileURL = $('valida_inputs').first().json.fileURL;\n\nlet content = '';\n\ntry {\n  // Formato Responses API: raw.output[].content[].text\n  const msgBlock = raw.output.find(o => o.type === 'message');\n  const textBlock = msgBlock.content.find(c => c.type === 'output_text');\n  content = textBlock.text;\n} catch (e) {\n  return [{ json: {\n    success: false,\n    error_code: 'API_RESPONSE_ERROR',\n    message: 'Formato de resposta inesperado da Responses API: ' + JSON.stringify(raw).substring(0, 400),\n    usuario_id, fileURL, lancamentos: [], total_fatura: 0,\n    suggestion: 'Verifique se o arquivo foi enviado corretamente para a Files API.'\n  }}];\n}\n\ncontent = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet parsed;\ntry {\n  const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n  if (!jsonMatch) throw new Error('JSON não encontrado');\n  parsed = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  return [{ json: {\n    success: false,\n    error_code: 'PARSE_ERROR',\n    message: 'Erro ao parsear JSON da IA: ' + e.message,\n    usuario_id, fileURL, lancamentos: [], total_fatura: 0,\n    suggestion: 'Verifique se o arquivo é uma fatura de cartão de crédito válida em PDF.'\n  }}];\n}\n\nif (!parsed.sucesso) {\n  return [{ json: {\n    success: false,\n    error_code: 'EXTRACTION_FAILED',\n    message: 'IA não conseguiu extrair os dados da fatura.',\n    usuario_id, fileURL, lancamentos: [], total_fatura: 0,\n    suggestion: 'Reenvie a fatura em PDF legível. Se for imagem, converta para PDF primeiro.'\n  }}];\n}\n\nreturn [{ json: {\n  success: true,\n  usuario_id,\n  fileURL,\n  vencimento: parsed.vencimento || '',\n  total_fatura: parseFloat(parsed.total_fatura) || 0,\n  lancamentos: parsed.lancamentos || [],\n  totais_por_categoria: parsed.totais_por_categoria || {},\n  resumo: parsed.resumo || '',\n  quantidade_lancamentos: (parsed.lancamentos || []).length\n}}];"
      },
