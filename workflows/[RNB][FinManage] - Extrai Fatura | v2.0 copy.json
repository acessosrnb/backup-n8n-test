    {
      "parameters": {
        "jsCode": "const fileId = $input.first().json.id;\nconst usuario_id = $('valida_inputs').first().json.usuario_id;\n\nif (!fileId) {\n  throw new Error('file_id ausente na resposta do Upload: ' + JSON.stringify($input.first().json).substring(0, 300));\n}\n\nconst prompt = \"Analise esta fatura de cartão de crédito e extraia TODOS os lançamentos.\\n\" +\n  \"Responda SOMENTE com JSON válido, sem markdown, sem explicações, no seguinte formato exato:\\n\" +\n  \"{\\\"sucesso\\\": true, \\\"vencimento\\\": \\\"dd/MM/yyyy\\\", \\\"total_fatura\\\": 0.00, \" +\n  \"\\\"lancamentos\\\": [{\\\"data\\\": \\\"dd/MM/yyyy\\\", \\\"descricao\\\": \\\"string\\\", \\\"valor\\\": 0.00, \" +\n  \"\\\"categoria\\\": \\\"string\\\", \\\"tipo\\\": \\\"debito|credito\\\"}], \" +\n  \"\\\"totais_por_categoria\\\": {\\\"categoria\\\": 0.00}, \\\"resumo\\\": \\\"string\\\"}\";\n\nconst requestBody = {\n  model: \"gpt-4.1\",\n  input: [\n    {\n      role: \"system\",\n      content: \"Você é um extrator especializado em faturas de cartão de crédito. Extraia TODOS os lançamentos com precisão. Responda APENAS com JSON válido, sem markdown, sem explicações.\"\n    },\n    {\n      role: \"user\",\n      content: [\n        { type: \"input_file\", file_id: fileId },\n        { type: \"input_text\", text: prompt }\n      ]\n    }\n  ]\n};\n\nreturn [{ json: { requestBody: JSON.stringify(requestBody), usuario_id } }];"
      },
