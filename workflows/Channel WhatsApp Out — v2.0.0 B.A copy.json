    {
      "parameters": {
        "jsCode": "// FN_SplitBaloes — extraído de secretary.amy em v2.0.0-B.A\n// Input: { chatid, raw_text }\n// Output: { output: \"<balao1>\\n<balao2>\\n...\" } — lista de balões concatenada por \\n\nconst raw = ($input.first().json.raw_text || '').toString();\nlet txt = raw\n  .replace(/```[\\s\\S]*?```/g, m => m.replace(/```/g,''))\n  .replace(/`([^`]*)`/g, '$1')\n  .replace(/\\*\\*([^*]+)\\*\\*/g, '$1')\n  .replace(/__([^_]+)__/g, '$1')\n  .replace(/\\*([^*]+)\\*/g, '$1')\n  .replace(/_([^_]+)_/g, '$1')\n  .replace(/^#{1,6}\\s+/gm, '')\n  .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1')\n  .replace(/^\\s*[-*+]\\s+/gm, '')\n  .replace(/^\\s*\\d+\\.\\s+/gm, '')\n  .replace(/\\r/g, '')\n  .trim();\nconst MAX = 700;\nconst paragraphs = txt.split(/\\n{2,}/).map(p => p.trim()).filter(Boolean);\nconst baloes = [];\nfor (const p of paragraphs) {\n  if (p.length <= MAX) { baloes.push(p); continue; }\n  const sentences = p.split(/(?<=[.!?])\\s+/);\n  let buf = '';\n  for (const s of sentences) {\n    if ((buf + ' ' + s).trim().length > MAX && buf) { baloes.push(buf.trim()); buf = s; }\n    else { buf = buf ? buf + ' ' + s : s; }\n  }\n  if (buf.trim()) baloes.push(buf.trim());\n}\nconst output = baloes.join('\\n');\nreturn [{ json: { output } }];\n"
      },
      "id": "6180d7b0-80dc-4f7f-aba5-ffd7667282e8",
      "name": "FN_SplitBaloes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const txt = $input.first().json.output || '';\nif (!txt.trim()) return [];\nconst arr = txt.replace(/\\\\n/g,'\\n').split(/\\n/).map(l=>l.trim()).filter(l=>l.length>0);\nreturn arr.map(msg => ({ json: { output: msg } }));\n"
      },
