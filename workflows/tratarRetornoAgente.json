    {
      "parameters": {
        "jsCode": "const rawOutput = $input.item.json.retornoAgente || \"\";\n\n// Função para limpar o texto em etapas\nfunction cleanAgentOutput(text) {\n  if (!text) return \"\";\n\n  let cleaned = text;\n\n  // 1. Remove blocos de código Markdown (```json ... ```)\n  cleaned = cleaned.replace(/```[\\s\\S]*?```/g, \"\");\n\n  // 2. Remove metadados entre colchetes [ ... ]\n  // Ex: [Pensando...], [Tool_Use: ...]\n  cleaned = cleaned.replace(/\\[[\\s\\S]*?\\]/g, \"\");\n\n  // 3. Remove linhas de comando de ferramenta (que começam com /)\n  // Ex: /atualizar_kanban {\"a\": 1}\n  // O 'm' no final faz o ^ funcionar para cada linha\n  cleaned = cleaned.replace(/^\\s*\\/[\\w_-]+.*$/gm, \"\");\n\n  // 4. Remove objetos JSON soltos { ... }\n  // Isso pega qualquer coisa que pareça um objeto JSON técnico\n  cleaned = cleaned.replace(/\\{[\\s\\S]*?\\}/g, \"\");\n\n  // 5. Limpeza final de pontuação \"suja\"\n  // Remove sobras de colchetes ou aspas que podem ter ficado\n  cleaned = cleaned.replace(/^[\\])}]+/, \"\"); // Remove ] ou ) ou } no começo\n\n  // 6. Remove excesso de linhas em branco e espaços\n  cleaned = cleaned.replace(/\\n\\s*\\n/g, \"\\n\").trim();\n\n  return cleaned;\n}\n\nconst textoFinal = cleanAgentOutput(rawOutput);\n\nreturn [\n  {\n    json: {\n      texto_original: rawOutput,\n      texto_limpo: textoFinal\n    }\n  }\n];"
      },
