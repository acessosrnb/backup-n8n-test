      "name": "buscarCustosDoModelo"
    },
    {
      "parameters": {
        "jsCode": "// Pega input e output\nconst input = $('executarFluxo').first().json.input;\nconst output = $('executarFluxo').first().json.output;\nconst llmModel = $('executarFluxo').first().json.llmModel;\n\n\n// Estima tokens (1.5 tokens por palavra em português)\nconst estimateTokens = (text) => {\n  if (!text) return 0;\n  const words = text.split(/\\s+/).length;\n  return Math.ceil(words * 1.5);\n};\n\nconst inputTokens = estimateTokens(input);\nconst outputTokens = estimateTokens(output);\nconst totalTokens = inputTokens + outputTokens;\n\n// Preços GPT-4o (por 1M tokens)\nconst precoInput = $input.first().json.input_price;   // $2.50 por 1M input\nconst precoOutput = $input.first().json.output_price; // $10.00 por 1M output\n\n// Cotação dólar\nconst dolar = $input.first().json.dolar;\n\n// Calcula custo\nconst custoUSD = ((inputTokens / 1_000_000) * precoInput) + ((outputTokens / 1_000_000) * precoOutput);\nconst custoBRL = custoUSD * dolar;\n\nreturn {\n  output: output,\n  input_tokens: inputTokens,\n  output_tokens: outputTokens,\n  total_tokens: totalTokens,\n  model: llmModel,\n  custo_usd: Number(custoUSD.toFixed(8)),\n  custo_brl: Number(custoBRL.toFixed(6))\n};"
      },
      "type": "n8n-nodes-base.code",
