      {
        "parameters": {
          "jsCode": "// Run Once for All Items\nconst items = $input.all();\n\n// Extrai e converte cada CostUSD\nconst costs = items.map(item => parseFloat(item.json.CostUSD) || 0);\n\n// Soma tudo\nconst total = costs.reduce((sum, c) => sum + c, 0);\n\n// Retorna um único item com o array de custos e o total\nreturn [\n  {\n    json: {\n      costs,                                 // [0.002776, 0.003028, …]\n      totalCostUSD: Number(total.toFixed(6)) // arredonda em 2 casas\n    }\n  }\n];\n"
        },
