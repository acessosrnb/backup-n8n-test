    {
      "parameters": {
        "jsCode": "// Inputs\nconst appointments = $('buscarAgendamentosPendentes').all().map(i => i.json);\nconst configs = $('buscarConfigsDeIA').all().map(i => i.json);\n\nconst remindersToSend = [];\nconst now = new Date();\n\n// Cria mapa de configs por Organization ID para acesso rápido\nconst configMap = {};\nconfigs.forEach(c => {\n  configMap[c.id_organizacao] = c;\n});\n\nfor (const appt of appointments) {\n  const config = configMap[appt.id_organizacao];\n  \n  // Se não tiver config para essa empresa, pula\n  if (!config) continue;\n\n  // Pega telefone do paciente (precisamos fazer lookup na tabela patients ou assumir que vem no appointment? \n  // No seu schema appointment tem patient_id. Vou assumir que precisamos buscar o telefone ou ele já vem num join.\n  // O ideal seria fazer um Join no Supabase node, mas vamos assumir que você consegue o telefone.\n  // PROVISÓRIO: Vou assumir que conseguimos pegar o telefone em outro passo ou ele está no appointment (se vc alterou).\n  // Se não estiver, precisaremos de um passo extra de \"Get Patient\".\n  \n  const start = new Date(appt.inicio);\n  const diffMs = start - now;\n  const diffMinutes = Math.floor(diffMs / 1000 / 60);\n\n  // Definição de tolerância (janela de envio) para não perder o minuto exato\n  // Ex: Se o cron rodar 14:01 e o lembrete era 14:00, aceitamos até 2 min de atraso\n  const tolerance = 2;\n\n  // --- Lembrete 1 ---\n  // Ex: Faltam 15 min\n  const r1 = config.lembrete_1_enviado || 15;\n  if (diffMinutes <= r1 && diffMinutes > (r1 - tolerance) && !appt.reminder_1_sent) {\n    remindersToSend.push({\n      type: 'reminder_1',\n      minutes_left: r1,\n      appt_id: appt.id,\n      id_contato: appt.id_contato,\n      nome_contato: appt.nome_contato,\n      appt_time: appt.hora,\n      org_id: appt.id_organizacao,\n      config: config\n    });\n    continue; // Envia apenas um por vez\n  }\n\n  // --- Lembrete 2 ---\n  // Ex: Faltam 60 min\n  const r2 = config.lembrete_2_enviado || 60;\n  if (diffMinutes <= r2 && diffMinutes > (r2 - tolerance) && !appt.reminder_2_sent) {\n    remindersToSend.push({\n      type: 'reminder_2',\n      minutes_left: r2,\n      appt_id: appt.id,\n      id_contato: appt.id_contato,\n      nome_contato: appt.nome_contato,\n      appt_time: appt.hora,\n      org_id: appt.id_organizacao,\n      config: config\n    });\n    continue;\n  }\n\n  // --- Lembrete 3 ---\n  // Ex: Faltam 1440 min (24h)\n  const r3 = config.lembrete_3_enviado || 1440;\n  if (diffMinutes <= r3 && diffMinutes > (r3 - tolerance) && !appt.reminder_3_sent) {\n    remindersToSend.push({\n      type: 'reminder_3',\n      minutes_left: r3,\n      appt_id: appt.id,\n      id_contato: appt.id_contato,\n      nome_contato: appt.nome_contato,\n      appt_time: appt.hora,\n      org_id: appt.id_organizacao,\n      config: config\n    });\n    continue;\n  }\n}\n\nreturn remindersToSend.map(r => ({ json: r }));"
      },
