          }
        }
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst agora = new Date();\nconst resultado = [];\n\nfor (const item of items) {\n  const d = item.json;\n\n  if (d.status_evento === 'Cancelado') continue;\n  if (d.lembrete_30min_enviado === 'sim') continue;\n  if (!d.telefone_lead || !d.hora_inicio || !d.data_de_inicio) continue;\n\n  // Offset -03:00 para tratar como horário de Brasília\n  const eventDate = new Date(d.data_de_inicio + 'T' + d.hora_inicio + ':00-03:00');\n\n  const diffMin = (eventDate.getTime() - agora.getTime()) / 60000;\n\n  if (diffMin >= 25 && diffMin <= 35) {\n    let tel = String(d.telefone_lead).replace(/\\D/g, '');\n    if (tel.length === 10 || tel.length === 11) tel = '55' + tel;\n\n    const nome = (d.nome_lead || '').split(' ')[0] || '';\n    const meetLink = d.link_reuniao || '';\n\n    const msg = `${nome}, 30 minutos! 🔔\\n\\n👉 ${meetLink || d.hora_inicio + 'h'}`;\n\n    resultado.push({ json: { number: tel, text: msg, id_agendamento: d.id_agendamento } });\n  }\n}\n\nreturn resultado.length > 0 ? resultado : [];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2368,
          320
        ],
