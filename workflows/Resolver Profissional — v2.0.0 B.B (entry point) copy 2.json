    {
      "parameters": {
        "jsCode": "// FN_MatchProfissional — resolver entry point v2.0.0-B.B\n// Input: lista de profissionais ativos (do Supabase) + trigger com campos de scheduling.\n// Output enriquecido: passa adiante todos os campos do trigger + profissional_nome + calendar_id.\n//   - encontrado=true: { encontrado, profissional_nome, calendar_id, lista_nomes, duvida, 'Identificador Lead', servico, nomeCliente }\n//   - encontrado=false: { encontrado: false, lista_nomes, response }\nconst trigger = $('When_Executed_by_Another_Workflow').first().json;\nconst profissionais = $input.all().map(i => i.json).filter(p => p && p.nome);\nconst pedido = (trigger.profissional || '').trim().toLowerCase();\n\nif (profissionais.length === 0) {\n  return [{ json: {\n    encontrado: false,\n    lista_nomes: '',\n    response: 'Nenhum profissional disponível no momento. Tente novamente mais tarde.'\n  }}];\n}\n\nconst nomes = profissionais.map(p => p.apelido || p.nome).join(', ');\n\nconst carryTrigger = {\n  duvida: trigger.duvida,\n  'Identificador Lead': trigger['Identificador Lead'],\n  servico: trigger.servico,\n  nomeCliente: trigger.nomeCliente\n};\n\n// Fallback: cliente não informou → primeiro ativo\nif (!pedido) {\n  const p = profissionais[0];\n  return [{ json: {\n    encontrado: true,\n    profissional_nome: p.nome,\n    calendar_id: p.calendar_id,\n    lista_nomes: nomes,\n    ...carryTrigger\n  }}];\n}\n\n// Match flexível: nome ou apelido contém (ou é contido por) o pedido\nconst match = profissionais.find(p => {\n  const nome = (p.nome || '').toLowerCase();\n  const apelido = (p.apelido || '').toLowerCase();\n  return nome.includes(pedido) || apelido.includes(pedido) || pedido.includes(nome) || (apelido && pedido.includes(apelido));\n});\n\nif (match) {\n  return [{ json: {\n    encontrado: true,\n    profissional_nome: match.nome,\n    calendar_id: match.calendar_id,\n    lista_nomes: nomes,\n    ...carryTrigger\n  }}];\n}\n\nreturn [{ json: {\n  encontrado: false,\n  lista_nomes: nomes,\n  response: `Não encontrei o profissional \"${trigger.profissional}\". Nossos profissionais disponíveis são: ${nomes}. Qual você prefere?`\n}}];\n"
      },
