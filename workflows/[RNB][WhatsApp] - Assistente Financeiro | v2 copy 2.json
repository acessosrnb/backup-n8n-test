        "jsCode": "if (!items || items.length === 0 || !items[0].json.Tipo) {\n  return [{ json: { mensagem: 'Nenhuma transacao registrada nos ultimos 90 dias.' } }];\n}\nconst messages = items.map(item =>\n  `[${item.json.Tipo}] ${item.json.Categoria} - ${item.json['Sub-categoria']} - ${item.json.Valor} (${item.json.Data})`\n);\nreturn [{ json: { mensagem: messages.join('\\n') } }];"
