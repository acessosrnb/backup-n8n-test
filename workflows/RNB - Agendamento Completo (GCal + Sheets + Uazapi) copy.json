        "jsCode": "const data = $('Code - Extrair Dados e Montar Mensagens').first().json;\nconst startISO = data.startISO;\nif (!startISO) return [];\n\nconst startTime = new Date(startISO).getTime();\nconst now = Date.now();\nconst waitMs = startTime - now - (60 * 60 * 1000);\n\nif (waitMs <= 0) return [];\n\nreturn [{ json: { ...data, waitSeconds: Math.floor(waitMs / 1000) } }];"
