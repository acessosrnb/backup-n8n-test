        "id": "19b05d21-7076-4637-820f-7a60e95eb771",
        "name": "When_Executed_by_Another_Workflow",
        "type": "n8n-nodes-base.executeWorkflowTrigger",
        "typeVersion": 1.1,
        "position": [
          128,
          64
        ]
      },
      {
        "parameters": {
          "jsCode": "// FN_SplitBaloes v2.0.2 (MSG-01) — MAX=1800; sem split por parágrafos (\\n\\n).\n// Regra: se o texto total cabe em MAX → 1 balão (preserva \\n internos).\n// Se > MAX → empacota por frases; frase isolada > MAX → fatia dura (raro).\nconst raw = ($input.first().json.raw_text || '').toString();\nlet txt = raw\n  .replace(/```[\\s\\S]*?```/g, m => m.replace(/```/g,''))\n  .replace(/`([^`]*)`/g, '$1')\n  .replace(/\\*\\*([^*]+)\\*\\*/g, '$1')\n  .replace(/__([^_]+)__/g, '$1')\n  .replace(/\\*([^*]+)\\*/g, '$1')\n  .replace(/_([^_]+)_/g, '$1')\n  .replace(/^#{1,6}\\s+/gm, '')\n  .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1')\n  .replace(/\\r/g, '')\n  .trim();\n\nif (!txt) return [];\n\nconst MAX = 1800;\n\nif (txt.length <= MAX) {\n  return [{ json: { output: txt } }];\n}\n\nconst pieces = txt.split(/(?<=[.!?…])\\s+/).map(s => s.trim()).filter(Boolean);\nconst sent = pieces.length ? pieces : [txt];\nconst baloes = [];\nlet buf = '';\nfor (const s of sent) {\n  if (s.length > MAX) {\n    if (buf.trim()) { baloes.push(buf.trim()); buf = ''; }\n    for (let i = 0; i < s.length; i += MAX) {\n      baloes.push(s.slice(i, i + MAX));\n    }\n    continue;\n  }\n  const candidate = buf ? buf + ' ' + s : s;\n  if (candidate.length > MAX && buf) {\n    baloes.push(buf.trim());\n    buf = s;\n  } else {\n    buf = candidate;\n  }\n}\nif (buf.trim()) baloes.push(buf.trim());\nreturn baloes.map(b => ({ json: { output: b } }));"
        },
        "id": "f603cc58-a103-4e6c-8b54-3825553b585c",
        "name": "FN_SplitBaloes",
        "type": "n8n-nodes-base.code",
