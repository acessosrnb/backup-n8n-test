      "id": "773d5319-2fff-40ac-9a38-cc5167ccf76a",
      "name": "Transcreve com Google Gemini",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "position": [
        6000,
        2416
      ],
      "typeVersion": 1,
      "credentials": {
