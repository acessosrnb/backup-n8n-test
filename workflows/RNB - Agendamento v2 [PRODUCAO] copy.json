    {
      "parameters": {
        "jsCode": "const event = $input.first().json;\n\n// --- PARSING ROBUSTO (regex por padrao, nao por posicao) ---\nconst rawDesc = (event.description || '').replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ');\nconst lines = rawDesc.split(/[\\n\\r]+/).map(l => l.trim()).filter(l => l.length > 0);\n\nlet nome = '';\nlet email = '';\nlet telefone = '';\n\nfor (const line of lines) {\n  if (!email && /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(line)) {\n    email = line;\n  } else if (!telefone && /^[\\d\\s\\(\\)\\+\\-]{8,}$/.test(line)) {\n    telefone = line.replace(/\\D/g, '');\n  } else if (!nome && !/booked by/i.test(line) && !line.includes('http') && line.length >= 2 && line.length <= 100) {\n    nome = line;\n  }\n}\n\n// Fallback: attendees\nconst attendees = (event.attendees || []).filter(a => a.email !== event.creator?.email && a.email !== event.organizer?.email);\nif (!email && attendees.length > 0) {\n  email = attendees[0].email || '';\n  nome = nome || attendees[0].displayName || email.split('@')[0];\n}\n\n// Normalizacao telefone (aceita +55 88 9464-3319, 88988136242, 5588988136242)\nif (telefone) {\n  if (telefone.length === 10 || telefone.length === 11) telefone = '55' + telefone;\n  if (telefone.length < 12) return [];\n} else {\n  return [];\n}\n\n// --- DATA/HORA ---\nconst startRaw = event.start?.dateTime || '';\nlet dataFmt = '';\nlet horaFmt = '';\nlet dataInicio = '';\nlet horaInicio = '';\nlet diaSemana = '';\n\nif (startRaw) {\n  const dt = new Date(startRaw);\n  const dias = ['Domingo','Segunda-feira','Ter\\u00e7a-feira','Quarta-feira','Quinta-feira','Sexta-feira','S\\u00e1bado'];\n  diaSemana = dias[dt.getDay()];\n  const dd = String(dt.getDate()).padStart(2,'0');\n  const mm = String(dt.getMonth()+1).padStart(2,'0');\n  const yyyy = dt.getFullYear();\n  const hh = String(dt.getHours()).padStart(2,'0');\n  const min = String(dt.getMinutes()).padStart(2,'0');\n  dataFmt = `${diaSemana}, ${dd}/${mm}/${yyyy}`;\n  horaFmt = `${hh}:${min}h`;\n  dataInicio = `${yyyy}-${mm}-${dd}`;\n  horaInicio = `${hh}:${min}`;\n}\n\nconst meetLink = event.hangoutLink || (event.conferenceData?.entryPoints || []).find(e => e.entryPointType === 'video')?.uri || '';\nconst titulo = event.summary || 'Reuniao';\nconst primeiroNome = nome.split(' ')[0] || '';\nconst dataAgendamento = event.created ? event.created.split('T')[0] : new Date().toISOString().split('T')[0];\n\n// --- ASSINATURA (1 lugar para editar) ---\nconst assinatura = `---\\n\\nPrazer, me chamo Rog\\u00e9rio e sou Fundador da *RNB Solu\\u00e7\\u00f5es*, uma startup especializada em desenvolvimento de sistemas e automa\\u00e7\\u00f5es assistida por Intelig\\u00eancia Artificial.\\n\\nEstou disponibilizando meu contato e minha agenda para podermos marcar um bate papo inicial e assim eu posso entender a sua necessidade e assim ter condi\\u00e7\\u00f5es de te enviar uma proposta.\\n\\n*Contato:*\\n\\u{1F4F1} Celular: (17) 99184-1789\\n\\u{1F4E7} Email: rogerio@rnbsolucoes.com.br\\n\\u{1F4C5} Agenda: https://calendar.app.google/19uX8hWQsbfrmAM86\\n\\n*Saiba mais:*\\n\\u{1F310} Site: https://www.rnbsolucoes.com.br\\n\\u{1F4BC} Portf\\u00f3lio: https://rogerio.rnbsolucoes.com.br/\\n\\u{1F517} LinkedIn: https://www.linkedin.com/in/rogerio-rnb-solucoes/\\n\\nDesde j\\u00e1 agrade\\u00e7o e fico \\u00e0 disposi\\u00e7\\u00e3o!\\n\\nAtenciosamente\\n*Rog\\u00e9rio Borges*`;\n\nconst msgConfirmacao = `Ol\\u00e1 ${primeiroNome}, seu agendamento est\\u00e1 *confirmado*! \\u{2705}\\n\\n\\u{1F4C5} Data: ${dataFmt}\\n\\u{23F0} Hor\\u00e1rio: ${horaFmt}${meetLink ? `\\n\\u{1F4BB} Link: ${meetLink}` : ''}\\n\\n${assinatura}`;\n\nconst msgLembrete1h = `Ol\\u00e1 ${primeiroNome}! \\u{23F3}\\n\\nSua reuni\\u00e3o *${titulo}* come\\u00e7a em *1 hora*!\\n\\n\\u{23F0} ${horaFmt}${meetLink ? `\\n\\u{1F4BB} ${meetLink}` : ''}\\n\\nNos vemos em breve!\\n*Rog\\u00e9rio Borges - RNB Solu\\u00e7\\u00f5es*`;\n\nconst msgLembrete30min = `${primeiroNome}, faltam *30 minutos*! \\u{1F514}\\n\\nSua reuni\\u00e3o come\\u00e7a \\u00e0s *${horaFmt}*${meetLink ? `\\n\\n\\u{1F449} Acesse aqui: ${meetLink}` : ''}\\n\\nTe espero l\\u00e1!\\n*Rog\\u00e9rio Borges*`;\n\nreturn [{\n  json: {\n    number: telefone,\n    nome_lead: nome,\n    primeiroNome,\n    email,\n    id_agendamento: event.id || '',\n    data_agendamento: dataAgendamento,\n    status_evento: 'Agendamento',\n    data_de_inicio: dataInicio,\n    hora_inicio: horaInicio,\n    link_reuniao: meetLink,\n    dia_da_semana_evento: diaSemana,\n    data_cancelamento: '',\n    motivo_cancelamento: '',\n    telefone_lead: telefone,\n    titulo,\n    msgConfirmacao,\n    msgLembrete1h,\n    msgLembrete30min,\n    startISO: startRaw\n  }\n}];"
      },
