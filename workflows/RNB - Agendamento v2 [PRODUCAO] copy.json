      "parameters": {
        "jsCode": "const data = $('Code - Extrair e Montar').first().json;\nconst startISO = data.startISO;\nif (!startISO) return [];\n\nconst startMs = new Date(startISO).getTime();\nconst nowMs = Date.now();\nconst waitMs = startMs - nowMs - (60 * 60 * 1000);\n\nif (waitMs <= 60000) return [];\n\nreturn [{ json: { ...data, waitSeconds: Math.floor(waitMs / 1000) } }];"
      },
