    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst payload = raw.body || raw;\nconst message = payload.message || {};\nconst chat = payload.chat || {};\n\nif (message.fromMe === true) {\n  return [];\n}\n\nconst texto = String(message.text || message.content || '').trim().toLowerCase();\nif (texto !== 'rnbaifestival') {\n  return [];\n}\n\nconst telefoneBruto = message.sender_pn || chat.phone || '';\nconst telefone = String(telefoneBruto).replace(/\\D/g, '');\n\nif (!telefone || telefone.length < 10) {\n  return [];\n}\n\nconst nome = String(message.senderName || chat.wa_contactName || chat.name || chat.wa_name || 'Visitante');\n\nconst saudacao = `Obrigado pelo contato, ${nome}!`;\n\nconst msg = `${saudacao} \\u{1F44B}\\n\\nPrazer, me chamo Rogério e sou Fundador da *RNB Soluções*, uma startup especializada em desenvolvimento de sistemas e automações assistida por Inteligência Artificial.\\n\\nEstou disponibilizando meu contato e minha agenda para podermos marcar um bate papo inicial e assim eu posso entender a sua necessidade e assim ter condições de te enviar uma proposta.\\n\\n*Contato:*\\n\\u{1F4F1} Celular: (17) 99184-1789\\n\\u{1F4E7} Email: rogerio@rnbsolucoes.com.br\\n\\u{1F4C5} Agenda: https://calendar.app.google/19uX8hWQsbfrmAM86\\n\\nGostaria de aproveitar o contato e disponibilizar também mais informações sobre nós.\\n\\n*Saiba mais:*\\n\\u{1F310} Site: https://www.rnbsolucoes.com.br\\n\\u{1F4BC} Portfólio: https://rogerio.rnbsolucoes.com.br/\\n\\u{1F517} LinkedIn: https://www.linkedin.com/in/rogerio-rnb-solucoes/\\n\\nDesde já agradeço o contato e fico à disposição para esclarecer qualquer dúvida.\\n\\nAtenciosamente\\n*Rogério Borges*`;\n\nreturn [{\n  json: {\n    nome: nome,\n    numero: telefone,\n    text: msg,\n    data_hora: new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' })\n  }\n}];"
      },
