    },
    {
      "parameters": {
        "jsCode": "try {\n  const input = $input.first().json;\n  const confirm = input.confirm || '';\n  const mode = input.mode || '';\n  const usuario_ids = input.usuario_ids || [];\n\n  if (confirm !== 'RESETAR') {\n    return [{\n      json: {\n        success: false,\n        bloqueado: true,\n        mensagem: 'BLOQUEADO: campo confirm deve ser exatamente \"RESETAR\". Recebido: \"' + confirm + '\"',\n        timestamp: new Date().toISOString()\n      }\n    }];\n  }\n\n  if (mode !== 'full' && mode !== 'user') {\n    return [{\n      json: {\n        success: false,\n        bloqueado: true,\n        mensagem: 'BLOQUEADO: campo mode deve ser \"full\" ou \"user\". Recebido: \"' + mode + '\"',\n        timestamp: new Date().toISOString()\n      }\n    }];\n  }\n\n  if (mode === 'user' && (!Array.isArray(usuario_ids) || usuario_ids.length === 0)) {\n    return [{\n      json: {\n        success: false,\n        bloqueado: true,\n        mensagem: 'BLOQUEADO: modo \"user\" requer campo usuario_ids com array de IDs',\n        timestamp: new Date().toISOString()\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      confirmado: true,\n      mode,\n      usuario_ids,\n      is_full: mode === 'full',\n      is_user: mode === 'user',\n      timestamp: new Date().toISOString()\n    }\n  }];\n} catch (e) {\n  return [{\n    json: {\n      success: false,\n      bloqueado: true,\n      mensagem: 'ERRO: ' + e.message,\n      timestamp: new Date().toISOString()\n    }\n  }];\n}"
      },
