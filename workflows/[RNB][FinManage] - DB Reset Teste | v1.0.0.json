      "parameters": {
        "jsCode": "try {\n  const mov = $('DB-F - Movimentacoes').first().json.deletados || 0;\n  const itens = $('DB-F - Itens Fatura').first().json.deletados || 0;\n  const fat = $('DB-F - Faturas').first().json.deletados || 0;\n  const contas = $('DB-F - Contas').first().json.deletados || 0;\n  const map = $('DB-F - Mapeamento').first().json.deletados || 0;\n  const chat = $('DB-F - Chat Histories').first().json.deletados || 0;\n  const met = $('DB-F - Metricas').first().json.deletados || 0;\n  const total = Number(mov)+Number(itens)+Number(fat)+Number(contas)+Number(map)+Number(chat)+Number(met);\n  return [{json:{success:true,mode:'full',timestamp:new Date().toISOString(),resultado:{movimentacoes:Number(mov),itens_fatura:Number(itens),faturas:Number(fat),contas:Number(contas),mapeamento_categorias:Number(map),n8n_chat_histories:Number(chat),metricas_sistema:Number(met),sequences_resetadas:true},total_registros_deletados:total}}];\n} catch(e) { return [{json:{success:false,erro:e.message}}]; }"
