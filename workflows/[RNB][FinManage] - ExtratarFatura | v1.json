    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst erros = [];\n\nif (!item.fileURL || item.fileURL.trim() === '') {\n  erros.push('Parâmetro obrigatório ausente: fileURL');\n}\nif (!item.usuario_id || item.usuario_id.trim() === '') {\n  erros.push('Parâmetro obrigatório ausente: usuario_id');\n}\n\nif (erros.length > 0) {\n  return [{ json: { inputs_validos: false, erros, fileURL: item.fileURL, usuario_id: item.usuario_id } }];\n}\n\nreturn [{ json: { inputs_validos: true, erros: [], fileURL: item.fileURL, usuario_id: item.usuario_id } }];"
      },
