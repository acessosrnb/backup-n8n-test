      "id": "5048d0f3-4d92-4448-8d54-232e3b4bae0f",
      "name": "if_extracao_sucesso",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        9264,
        1968
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst usuario_id = $('valida_inputs').first().json.usuario_id;\nconst fileURL = $('valida_inputs').first().json.fileURL;\n\ntry {\n  const rawContent = item.choices?.[0]?.message?.content || '';\n  const jsonMatch = rawContent.match(/\\{[\\s\\S]*\\}/);\n  if (!jsonMatch) throw new Error('JSON nao encontrado na resposta da OpenAI');\n  const parsed = JSON.parse(jsonMatch[0]);\n\n  if (!parsed.sucesso) throw new Error('Extracao retornou sucesso=false');\n\n  return [{\n    json: {\n      success: true,\n      usuario_id,\n      fileURL,\n      vencimento: parsed.vencimento || '',\n      total_fatura: parsed.total_fatura || 0,\n      lancamentos: parsed.lancamentos || [],\n      totais_por_categoria: parsed.totais_por_categoria || {},\n      resumo: parsed.resumo || '',\n      quantidade_lancamentos: (parsed.lancamentos || []).length\n    }\n  }];\n} catch (e) {\n  return [{\n    json: {\n      success: false,\n      error_code: 'PARSE_ERROR',\n      message: 'Erro ao processar resposta da IA: ' + e.message,\n      usuario_id,\n      fileURL,\n      lancamentos: [],\n      total_geral: 0,\n      suggestion: 'Verifique se o arquivo enviado é uma fatura de cartão de crédito válida em formato PDF.'\n    }\n  }];\n}"
      },
      "id": "59af8d29-332b-405a-8cf4-2972798b43fb",
      "name": "parseia_resposta_openai",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        9008,
        1968
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"gpt-4.1\", \"max_tokens\": 4000, \"messages\": [{\"role\": \"user\", \"content\": [{\"type\": \"text\", \"text\": \"Analise esta fatura de cartão de crédito e extraia TODOS os lançamentos. Responda SOMENTE com JSON válido, sem explicações, no seguinte formato exato:\\n{\\\"sucesso\\\": true, \\\"vencimento\\\": \\\"dd/MM/yyyy\\\", \\\"total_fatura\\\": 0.00, \\\"lancamentos\\\": [{\\\"data\\\": \\\"dd/MM/yyyy\\\", \\\"descricao\\\": \\\"string\\\", \\\"valor\\\": 0.00, \\\"categoria\\\": \\\"string\\\", \\\"tipo\\\": \\\"debito|credito\\\"}], \\\"totais_por_categoria\\\": {\\\"categoria\\\": 0.00}, \\\"resumo\\\": \\\"string\\\"}\"}, {\"type\": \"image_url\", \"image_url\": {\"url\": \"={{ 'data:' + $json.mime_type + ';base64,' + $json.pdf_base64 }}\"}}]}]}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "61806026-6f9f-4343-833a-cd381923332b",
      "name": "extrai_dados_fatura_openai",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        8752,
        1968
      ],
      "credentials": {
        "openAiApi": {
          "id": "PKDbkzhf4tikHNrE",
          "name": "[OpenAi] - Vitrine"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binaryKey = Object.keys(item.binary || {})[0];\n\nif (!binaryKey) {\n  return [{ json: { success: false, error_code: 'DOWNLOAD_ERROR', message: 'Falha ao baixar o arquivo da fatura.', lancamentos: [], total_geral: 0 } }];\n}\n\nconst base64 = item.binary[binaryKey].data;\nconst mimeType = item.binary[binaryKey].mimeType || 'application/pdf';\n\nreturn [{ json: { ...item.json, pdf_base64: base64, mime_type: mimeType, usuario_id: $('valida_inputs').first().json.usuario_id } }];"
      },
