    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO finmanage_faturas (usuario_id, file_url, vencimento, total_fatura, lancamentos, totais_por_categoria, created_at) VALUES ($1, $2, $3, $4, $5::jsonb, $6::jsonb, NOW()) ON CONFLICT (usuario_id, file_url) DO UPDATE SET lancamentos = EXCLUDED.lancamentos, totais_por_categoria = EXCLUDED.totais_por_categoria, updated_at = NOW() RETURNING id;",
        "options": {
          "queryReplacement": "={{ $json.usuario_id }},={{ $json.fileURL }},={{ $json.vencimento }},={{ $json.total_fatura }},={{ JSON.stringify($json.lancamentos) }},={{ JSON.stringify($json.totais_por_categoria) }}"
        }
      },
