    {
      "parameters": {
        "jsCode": "const itens = $input.all();\n\nconst datas = [];\nconst transacoes = [];\nconst categorias = [];\nconst entradas = [];\nconst saidas = [];\nconst hashes = [];\nconst usuario_ids = [];\n\nfor (const it of itens) {\n  const item = it.json;\n  const dataLanc = item.data_lancamento || '';\n  const isCredito = item.tipo === 'credito';\n  const valor = Number(item.valor) || 0;\n  const hash = 'fat_' + item.fatura_id + '_' + item.id;\n\n  datas.push(dataLanc || null);\n  transacoes.push(item.descricao);\n  categorias.push(item.categoria_nome || 'Fatura Cartão');\n  entradas.push(isCredito ? valor : 0);\n  saidas.push(isCredito ? 0 : valor);\n  hashes.push(hash);\n  usuario_ids.push(item.usuario_id);\n}\n\nreturn [{ json: { datas, transacoes, categorias, entradas, saidas, hashes, usuario_ids, total: itens.length } }];"
      },
      "id": "16e6502b-1c88-4a42-b4c3-a3e2e43fcfd5",
      "name": "prepara_bulk_insert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        268496,
        121600
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO movimentacoes (data, transacao, categoria, entrada, saida, origem, hash_dedup, usuario_id)\nSELECT\n  COALESCE(NULLIF(d,'')::date, NOW()::date),\n  t, c, e::numeric, s::numeric,\n  'fatura_cartao',\n  h, u\nFROM unnest(\n  $1::text[], $2::text[], $3::text[],\n  $4::text[], $5::text[], $6::text[], $7::text[]\n) AS u(d, t, c, e, s, h, u)\nON CONFLICT (hash_dedup) DO NOTHING\nRETURNING id",
        "options": {
          "queryReplacement": "={{ [$json.datas, $json.transacoes, $json.categorias, $json.entradas.map(String), $json.saidas.map(String), $json.hashes, $json.usuario_ids] }}"
        }
      },
