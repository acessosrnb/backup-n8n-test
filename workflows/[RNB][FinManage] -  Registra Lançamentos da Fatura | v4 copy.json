    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  i.id,\n  i.fatura_id,\n  i.usuario_id,\n  i.data_lancamento::text,\n  i.descricao,\n  i.estabelecimento,\n  i.valor,\n  i.tipo,\n  COALESCE(c.nome, 'Fatura Cartão') as categoria_nome\nFROM itens_fatura i\nLEFT JOIN categorias c ON c.id = i.categoria_id\nWHERE i.fatura_id = $1\n  AND i.usuario_id = $2\nORDER BY i.data_lancamento, i.id",
        "options": {
          "queryReplacement": "={{ [$('valida_inputs').item.json.fatura_id, $('valida_inputs').item.json.usuario_id] }}"
        }
