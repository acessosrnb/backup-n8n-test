      "parameters": {
        "jsCode": "const event = $input.first().json;\n\n// --- CLASSIFICAR TIPO ---\nconst isCancelled = event.status === 'cancelled';\n\nif (isCancelled) {\n  const id = event.id || '';\n  const rawDesc = (event.description || '').replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ');\n  const telMatch = rawDesc.match(/[\\d\\s\\(\\)\\+\\-]{10,}/);\n  let telefone = telMatch ? telMatch[0].replace(/\\D/g, '') : '';\n  if (telefone.length === 10 || telefone.length === 11) telefone = '55' + telefone;\n  const lines = rawDesc.split(/[\\n\\r]+/).map(l => l.trim()).filter(l => l.length > 0);\n  let nome = '';\n  for (const line of lines) {\n    if (!/booked by/i.test(line) && !line.includes('@') && !line.includes('http') && !/^[\\d\\s\\(\\)\\+\\-]+$/.test(line) && line.length >= 2 && line.length <= 100) {\n      nome = line; break;\n    }\n  }\n  const primeiroNome = nome.split(' ')[0] || '';\n  return [{ json: {\n    id_agendamento: id, status_evento: 'Cancelado',\n    data_cancelamento: new Date().toISOString().split('T')[0],\n    number: telefone, nome_lead: nome, telefone_lead: telefone,\n    msgPrincipal: telefone ? `Ol\\u00e1 ${primeiroNome || 'tudo bem'}? \\u{274C}\\n\\nSeu agendamento foi *cancelado*.\\n\\nSe desejar reagendar, acesse:\\n\\u{1F4C5} https://calendar.app.google/19uX8hWQsbfrmAM86\\n\\nAtenciosamente\\n*Rog\\u00e9rio Borges - RNB Solu\\u00e7\\u00f5es*` : '',\n    isCancelled: true, data_agendamento: '', data_de_inicio: '', hora_inicio: '',\n    link_reuniao: '', dia_da_semana_evento: '', motivo_cancelamento: ''\n  }}];\n}\n\n// --- PARSING ROBUSTO ---\nconst rawDesc = (event.description || '').replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ');\nconst lines = rawDesc.split(/[\\n\\r]+/).map(l => l.trim()).filter(l => l.length > 0);\nlet nome = '', email = '', telefone = '';\nfor (const line of lines) {\n  if (!email && /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(line)) email = line;\n  else if (!telefone && /^[\\d\\s\\(\\)\\+\\-]{8,}$/.test(line)) telefone = line.replace(/\\D/g, '');\n  else if (!nome && !/booked by/i.test(line) && !line.includes('http') && line.length >= 2 && line.length <= 100) nome = line;\n}\nconst attendees = (event.attendees || []).filter(a => a.email !== event.creator?.email && a.email !== event.organizer?.email);\nif (!email && attendees.length > 0) { email = attendees[0].email || ''; nome = nome || attendees[0].displayName || email.split('@')[0]; }\nif (telefone) {\n  if (telefone.length === 10 || telefone.length === 11) telefone = '55' + telefone;\n  if (telefone.length < 12) return [];\n} else return [];\n\n// --- DATA/HORA ---\nconst startRaw = event.start?.dateTime || '';\nlet dataFmt = '', horaFmt = '', dataInicio = '', horaInicio = '', diaSemana = '';\nif (startRaw) {\n  const dt = new Date(startRaw);\n  const dias = ['Domingo','Segunda-feira','Ter\\u00e7a-feira','Quarta-feira','Quinta-feira','Sexta-feira','S\\u00e1bado'];\n  diaSemana = dias[dt.getDay()];\n  const dd = String(dt.getDate()).padStart(2,'0');\n  const mm = String(dt.getMonth()+1).padStart(2,'0');\n  dataFmt = `${diaSemana}, ${dd}/${mm}/${dt.getFullYear()}`;\n  horaFmt = `${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}h`;\n  dataInicio = `${dt.getFullYear()}-${mm}-${dd}`;\n  horaInicio = `${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;\n}\nconst meetLink = event.hangoutLink || (event.conferenceData?.entryPoints || []).find(e => e.entryPointType === 'video')?.uri || '';\nconst titulo = event.summary || 'Reuniao';\nconst primeiroNome = nome.split(' ')[0] || '';\nconst dataAgendamento = event.created ? event.created.split('T')[0] : new Date().toISOString().split('T')[0];\nconst createdMs = event.created ? new Date(event.created).getTime() : 0;\nconst updatedMs = event.updated ? new Date(event.updated).getTime() : 0;\nconst isReagendamento = (updatedMs - createdMs) > 60000;\nconst statusEvento = isReagendamento ? 'Reagendado' : 'Agendamento';\n\n// --- ASSINATURA (unico lugar para editar) ---\nconst assinatura = `---\\n\\nPrazer, me chamo Rog\\u00e9rio e sou Fundador da *RNB Solu\\u00e7\\u00f5es*, uma startup especializada em desenvolvimento de sistemas e automa\\u00e7\\u00f5es assistida por Intelig\\u00eancia Artificial.\\n\\nEstou disponibilizando meu contato e minha agenda para podermos marcar um bate papo inicial e assim eu posso entender a sua necessidade e assim ter condi\\u00e7\\u00f5es de te enviar uma proposta.\\n\\n*Contato:*\\n\\u{1F4F1} Celular: (17) 99184-1789\\n\\u{1F4E7} Email: rogerio@rnbsolucoes.com.br\\n\\u{1F4C5} Agenda: https://calendar.app.google/19uX8hWQsbfrmAM86\\n\\n*Saiba mais:*\\n\\u{1F310} Site: https://www.rnbsolucoes.com.br\\n\\u{1F4BC} Portf\\u00f3lio: https://rogerio.rnbsolucoes.com.br/\\n\\u{1F517} LinkedIn: https://www.linkedin.com/in/rogerio-rnb-solucoes/\\n\\nDesde j\\u00e1 agrade\\u00e7o e fico \\u00e0 disposi\\u00e7\\u00e3o!\\n\\nAtenciosamente\\n*Rog\\u00e9rio Borges*`;\n\n// --- 3 MENSAGENS ---\nconst header = isReagendamento\n  ? `Ol\\u00e1 ${primeiroNome}, seu agendamento foi *reagendado*! \\u{1F504}`\n  : `Ol\\u00e1 ${primeiroNome}, seu agendamento est\\u00e1 *confirmado*! \\u{2705}`;\nconst detalhes = `\\u{1F4C5} Data: ${dataFmt}\\n\\u{23F0} Hor\\u00e1rio: ${horaFmt}${meetLink ? `\\n\\u{1F4BB} Link: ${meetLink}` : ''}`;\n\nconst msgPrincipal = `${header}\\n\\n${detalhes}\\n\\n${assinatura}`;\nconst msgLembrete1h = `Ol\\u00e1 ${primeiroNome}! \\u{23F3}\\n\\nSua reuni\\u00e3o *${titulo}* come\\u00e7a em *1 hora*!\\n\\n${detalhes}\\n\\nNos vemos em breve!\\n*Rog\\u00e9rio Borges - RNB Solu\\u00e7\\u00f5es*`;\nconst msgLembrete30min = `${primeiroNome}, faltam *30 minutos*! \\u{1F514}\\n\\nSua reuni\\u00e3o come\\u00e7a \\u00e0s *${horaFmt}*${meetLink ? `\\n\\n\\u{1F449} Acesse aqui: ${meetLink}` : ''}\\n\\nTe espero l\\u00e1!\\n*Rog\\u00e9rio Borges*`;\n\nreturn [{ json: {\n  number: telefone, nome_lead: nome, primeiroNome, email,\n  id_agendamento: event.id || '', data_agendamento: dataAgendamento,\n  status_evento: statusEvento, data_de_inicio: dataInicio,\n  hora_inicio: horaInicio, link_reuniao: meetLink,\n  dia_da_semana_evento: diaSemana, data_cancelamento: '',\n  motivo_cancelamento: '', telefone_lead: telefone, titulo,\n  msgPrincipal, msgLembrete1h, msgLembrete30min,\n  startISO: startRaw, isCancelled: false\n}}];"
      },
