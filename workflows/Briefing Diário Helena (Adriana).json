        "id": "f3a3637e-ad2a-48b4-bdbb-63b1e8a5d512",
        "name": "Buscar Previsão Clima",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          896,
          -32
        ],
        "continueOnFail": true
      },
      {
        "parameters": {
          "jsCode": "const parametros = $('Ajuste Parâmetros Diários').first().json;\n\n// Get all items from the chain (merge passed through http)\nconst allItems = $input.all();\n\n// Events come from Mesclar Eventos Agendas (accessible via node reference)\nlet eventosRaw = [];\ntry {\n  eventosRaw = $('Mesclar Eventos Agendas').all();\n} catch(e) {\n  eventosRaw = [];\n}\n\n// Weather comes from Buscar Previsão Clima (previous node)\nlet climaRaw = {};\ntry {\n  climaRaw = $('Buscar Previsão Clima').first().json;\n} catch(e) {\n  climaRaw = {};\n}\n\n// Process events\nconst eventos = eventosRaw\n  .filter(item => item.json && (item.json.summary || item.json.start))\n  .map(item => {\n    const e = item.json;\n    const inicio = e.start?.dateTime || e.start?.date || '';\n    const fim = e.end?.dateTime || e.end?.date || '';\n    \n    let horaInicio = '';\n    let horaFim = '';\n    let duracao = '';\n    \n    if (inicio.includes('T')) {\n      const startDt = new Date(inicio);\n      const endDt = new Date(fim);\n      horaInicio = startDt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', timeZone: 'America/Sao_Paulo' });\n      horaFim = endDt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', timeZone: 'America/Sao_Paulo' });\n      duracao = Math.round((endDt - startDt) / (1000 * 60)) + ' min';\n    } else {\n      horaInicio = 'Dia inteiro';\n      horaFim = '';\n      duracao = 'Dia inteiro';\n    }\n    \n    return {\n      titulo: e.summary || 'Sem título',\n      inicio: horaInicio,\n      fim: horaFim,\n      duracao: duracao,\n      descricao: e.description || '',\n      local: e.location || '',\n      timestamp: new Date(inicio).getTime() || 0\n    };\n  })\n  .sort((a, b) => a.timestamp - b.timestamp);\n\n// Process weather\nlet clima = { disponivel: false };\ntry {\n  if (climaRaw && climaRaw.forecast) {\n    const day = climaRaw.forecast.forecastday[0].day;\n    const current = climaRaw.current || {};\n    clima = {\n      disponivel: true,\n      condicao: day.condition?.text || 'Não disponível',\n      temp_min: day.mintemp_c,\n      temp_max: day.maxtemp_c,\n      umidade: day.avghumidity,\n      chance_chuva: day.daily_chance_of_rain,\n      uv: day.uv,\n      nascer_sol: climaRaw.forecast.forecastday[0].astro?.sunrise || '',\n      por_sol: climaRaw.forecast.forecastday[0].astro?.sunset || ''\n    };\n  }\n} catch (e) {\n  clima = { disponivel: false };\n}\n\nreturn {\n  json: {\n    data: parametros.data_formatada,\n    dia_semana: parametros.dia_semana,\n    total_eventos: eventos.length,\n    eventos: eventos,\n    clima: clima,\n    chat_id: parametros.chat_id\n  }\n};\n"
        },
        "id": "bed8cb83-2ee8-4dd8-86af-4b360f217c79",
        "name": "Montar Contexto Briefing",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1168,
          -32
        ]
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "=Você é Helena, assistente pessoal. Gere um briefing matinal completo para o dia {{ $json.dia_semana }}, {{ $json.data }}.\n\nDADOS DO DIA:\n\nEVENTOS ({{ $json.total_eventos }} compromissos):\n{{ JSON.stringify($json.eventos, null, 2) }}\n\nCLIMA:\n{{ JSON.stringify($json.clima, null, 2) }}\n\nINSTRUÇÕES:\n1. Escreva em português do Brasil, tom profissional mas leve.\n2. Comece com uma saudação matinal curta e contextualizada (considere o clima e o dia da semana).\n3. Se houver eventos, organize cronologicamente com:\n   - Horário e título\n   - Duração estimada\n   - Preparação necessária (o que fazer antes, materiais, contexto)\n   - Quanto tempo antes começar a se preparar\n   - Se precisa de deslocamento\n4. Entre eventos, sugira:\n   - Pausas estratégicas\n   - Janelas de foco produtivo\n   - Momentos para hidratação/alimentação\n5. Inclua o clima de forma útil (se vai chover: leve guarda-chuva; se vai estar quente: hidrate-se mais).\n6. Encerre com uma frase motivacional curta e prática.\n7. Se NÃO houver eventos: diga que o dia está livre e sugira como aproveitar produtivamente.\n8. Use apenas os dados fornecidos. Não invente eventos nem dados climáticos.\n9. Formate para leitura confortável no WhatsApp (sem markdown pesado, use emojis com moderação).\n10. Seja conciso — máximo 2000 caracteres."
        },
