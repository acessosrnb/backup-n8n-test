    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\n// Normaliza data para DD/MM/YYYY\nfunction normalizarData(dataStr) {\n  if (!dataStr) return null;\n  const s = String(dataStr).trim();\n\n  if (/^\\d{2}\\/\\d{2}\\/\\d{4}$/.test(s)) return s;\n\n  if (/^\\d{4}-\\d{2}-\\d{2}$/.test(s)) {\n    const [ano, mes, dia] = s.split('-');\n    return `${dia}/${mes}/${ano}`;\n  }\n\n  if (/^\\d{2}-\\d{2}-\\d{4}$/.test(s)) return s.replace(/-/g, '/');\n\n  const meses = {\n    'jan':'01','fev':'02','mar':'03','abr':'04','mai':'05','jun':'06',\n    'jul':'07','ago':'08','set':'09','out':'10','nov':'11','dez':'12',\n    'janeiro':'01','fevereiro':'02','março':'03','abril':'04','maio':'05',\n    'junho':'06','julho':'07','agosto':'08','setembro':'09','outubro':'10',\n    'novembro':'11','dezembro':'12'\n  };\n  const m = s.match(/^(\\d{1,2})\\s+([a-záàâãéêíóôõúç]+)\\.?\\s+(\\d{4})$/i);\n  if (m) {\n    const mes = meses[m[2].toLowerCase()];\n    if (mes) return `${m[1].padStart(2,'0')}/${mes}/${m[3]}`;\n  }\n\n  return null;\n}\n\nconst dataNormalizada = normalizarData(item.data_transacao);\n\n// Categoria: usa tipo como fallback se categoria não vier\nconst categoria = item.categoria || item.tipo || 'sem_categoria';\n\n// Resolve usuario_id do node de resolução\nconst usuarioId = $('Resolve Usuário — Extrato').first().json.usuario_id ?? null;\n\nreturn {\n  json: {\n    data_transacao: dataNormalizada,\n    descricao: item.descricao,\n    categoria: categoria,\n    entrada: Number(item.entrada) || 0,\n    saida: Number(item.saida) || 0,\n    data_valida: dataNormalizada !== null,\n    usuario_id: usuarioId,\n    _debug_data_original: item.data_transacao,\n    _debug_usuario: usuarioId  // remover após validação do Gate B\n  }\n};"
      },
