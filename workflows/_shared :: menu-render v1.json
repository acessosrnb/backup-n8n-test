        "jsCode": "const r = $input.first().json;\nconst b = $('FN_BuildUazapiMenuPayload').first().json;\nconst err = r.error;\nconst mid = r.messageid || r.messageId || (r.body && r.body.id) || null;\nconst sc = r.statusCode || 0;\nconst ok = !err && (sc === 200 || sc === 201 || !!mid);\nreturn [{ json: {\n  ok: ok,\n  messageId: mid,\n  sentAt: new Date().toISOString(),\n  echo: b.echo,\n  error: err ? JSON.stringify(err) : (ok ? undefined : ('http:' + sc + ' ' + JSON.stringify(r).slice(0, 400)))\n} }];"
