    {
      "parameters": {
        "jsCode": "const j = $input.first().json || {};\nconst t = String(j.type || '').toLowerCase();\nconst echoBase = { number: j.number, type: j.type, text: j.text, items: null, trackSource: j.trackSource, trackId: j.trackId, options: {} };\nif (!['button','list','poll'].includes(t)) {\n  return [{ json: { _err: 'bad_type', echo: Object.assign({}, echoBase, { items: null }) } }];\n}\nlet items = [];\ntry { items = JSON.parse(j.itemsJson || '[]'); } catch (e) {\n  return [{ json: { _err: 'bad_itemsJson', echo: Object.assign({}, echoBase, { items: null }) } }];\n}\nlet opt = {};\ntry { opt = JSON.parse(j.optionsJson || '{}'); } catch (e) { opt = {}; }\nconst num = String(j.number || '').replace(/\\D/g, '');\nif (!num) {\n  return [{ json: { _err: 'bad_number', echo: Object.assign({}, echoBase, { items: items, options: opt }) } }];\n}\nconst baseUrl = String(j.baseUrl || 'https://rnbsolucoes.uazapi.com').replace(/\\/$/, '');\nconst body = { number: num, type: t, text: String(j.text || ''), delay: opt.delay != null ? Number(opt.delay) : 500, track_source: String(j.trackSource || 'shared-menu'), track_id: String(j.trackId || 'turn') };\nif (t === 'button') {\n  body.choices = (items || []).map(function(it) { if (typeof it === 'string') return it; return (it.label || '') + '|' + (it.id || it.label || ''); });\n} else if (t === 'list') {\n  body.listButton = opt.listButton || 'Ver opções';\n  body.footerText = opt.footerText || '';\n  body.choices = (items || []).map(function(it) { return typeof it === 'string' ? it : (it.label || it.id || String(it)); });\n} else {\n  body.selectableCount = opt.selectableCount != null ? Number(opt.selectableCount) : 1;\n  body.choices = (items || []).map(function(it) { return typeof it === 'string' ? it : (it.label || it.id); });\n}\nconst echo = { number: j.number, type: t, text: j.text, items: items, trackSource: j.trackSource, trackId: j.trackId, options: opt };\nreturn [{ json: { baseUrl: baseUrl, body: body, echo: echo } }];"
      },
