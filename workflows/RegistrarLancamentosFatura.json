                "value": false,
                "type": "boolean"
              },
              {
                "id": "s2",
                "name": "error_code",
                "value": "NO_ITEMS",
                "type": "string"
              },
              {
                "id": "s3",
                "name": "message",
                "value": "Nenhum lançamento encontrado para esta fatura. Verifique se a extração foi concluída.",
                "type": "string"
              },
              {
                "id": "s4",
                "name": "response",
                "value": "⚠️ Nenhum lançamento encontrado para esta fatura. Verifique se a extração foi concluída corretamente.",
                "type": "string"
              }
            ]
          },
          "options": {}
        },
        "id": "f7e816f4-96b9-4e9c-a8be-a871f88cd6ec",
        "name": "OUT - Erro Sem Itens",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          272656,
          123680
        ]
      },
      {
        "parameters": {
          "jsCode": "try {\nconst itens = $input.all();\n\nconst datas = [];\nconst transacoes = [];\nconst categorias = [];\nconst entradas = [];\nconst saidas = [];\nconst hashes = [];\nconst usuario_ids = [];\n\nfor (const it of itens) {\n  const item = it.json;\n  const dataLanc = item.data_lancamento || '';\n  const isCredito = item.tipo === 'credito';\n  const valor = Number(item.valor) || 0;\n  const hash = 'fat_' + item.fatura_id + '_' + item.id;\n\n  datas.push(dataLanc || null);\n  transacoes.push(item.descricao);\n  categorias.push(item.categoria_nome || 'Fatura Cartão');\n  entradas.push(isCredito ? valor : 0);\n  saidas.push(isCredito ? 0 : valor);\n  hashes.push(hash);\n  usuario_ids.push(item.usuario_id);\n}\n\nreturn [{ json: { datas, transacoes, categorias, entradas, saidas, hashes, usuario_ids, total: itens.length } }];\n} catch (e) {\n  return [{ json: { success: false, error_code: 'CODE_ERROR', message: '[FN - Prepara Bulk Insert] ' + (e.message || 'Erro desconhecido') } }];\n}"
        },
        "id": "1bbadef0-fce2-4a78-a705-b0acea77f80f",
        "name": "FN - Prepara Bulk Insert",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          272976,
          123392
        ]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "INSERT INTO movimentacoes (data, transacao, categoria, entrada, saida, origem, hash_dedup, usuario_id)\nSELECT\n  COALESCE(NULLIF(d,'')::date, NOW()::date),\n  t, c, e::numeric, s::numeric,\n  'fatura_cartao',\n  h, u\nFROM unnest(\n  $1::text[], $2::text[], $3::text[],\n  $4::text[], $5::text[], $6::text[], $7::text[]\n) AS u(d, t, c, e, s, h, u)\nON CONFLICT (hash_dedup) DO NOTHING\nRETURNING id",
          "options": {
            "queryReplacement": "={{ [$json.datas, $json.transacoes, $json.categorias, $json.entradas.map(String), $json.saidas.map(String), $json.hashes, $json.usuario_ids] }}"
          }
        },
        "id": "43121f5f-cedb-455e-9827-7d414fda0c29",
        "name": "DB - Bulk Insert Movimentações",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.5,
        "position": [
          273296,
          123392
        ],
        "credentials": {
          "postgres": {
            "id": "lYJd0K4KbtjQBOZi",
            "name": "[Postgres] - acessos@"
          }
        },
        "onError": "continueErrorOutput",
        "retryOnFail": true,
        "maxTries": 2,
        "waitBetweenTries": 1000
      },
      {
        "parameters": {
          "assignments": {
            "assignments": [
              {
                "id": "be1",
                "name": "success",
                "value": false,
                "type": "boolean"
              },
              {
                "id": "be2",
                "name": "error_code",
