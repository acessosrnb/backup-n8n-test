                "type": "string"
              },
              {
                "id": "be3",
                "name": "message",
                "value": "={{ '⚠️ Falha ao inserir movimentações no banco. Erro: ' + ($json.error?.message || 'desconhecido') }}",
                "type": "string"
              },
              {
                "id": "be4",
                "name": "response",
                "value": "={{ '⚠️ Falha ao registrar lançamentos no banco. Tente novamente. Erro: ' + ($json.error?.message || 'desconhecido') }}",
                "type": "string"
              }
            ]
          },
          "options": {}
        },
        "id": "26d80590-ca9d-4dd9-86a6-2c3f63a11862",
        "name": "OUT - Erro Bulk",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          273296,
          123680
        ]
      },
      {
        "parameters": {
          "jsCode": "try {\nconst inseridos = $input.all().length;\nconst total = $('FN - Prepara Bulk Insert').first().json.total;\nconst jaExistiam = Math.max(0, total - inseridos);\nconst fatura_id = $('FN - Valida Inputs').first().json.fatura_id;\nconst usuario_id = $('FN - Valida Inputs').first().json.usuario_id;\n\nlet message;\nif (inseridos > 0 && jaExistiam > 0) {\n  message = '✅ ' + inseridos + ' lançamentos registrados. ' + jaExistiam + ' já existiam anteriormente.';\n} else if (inseridos > 0) {\n  message = '✅ ' + inseridos + ' lançamentos registrados nas movimentações com sucesso.';\n} else {\n  message = 'ℹ️ Todos os ' + total + ' lançamentos desta fatura já estavam registrados anteriormente.';\n}\n\nreturn [{ json: {\n  success: true,\n  fatura_id: fatura_id,\n  registros_inseridos: inseridos,\n  ja_existiam: jaExistiam,\n  total_processado: total,\n  message: message,\n  response: message,\n  usuario_id: usuario_id\n}}];\n} catch (e) {\n  return [{ json: { success: false, error_code: 'CODE_ERROR', message: '[OUT - Retorno Sucesso] ' + (e.message || 'Erro desconhecido'), response: '⚠️ Erro ao montar retorno.' } }];\n}"
        },
        "id": "48a3197e-cbc2-4702-9f0a-d8c9dbb4c003",
        "name": "OUT - Retorno Sucesso",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          273616,
          123392
        ]
      }
    ],
