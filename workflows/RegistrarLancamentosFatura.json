      "typeVersion": 1,
      "position": [
        270688,
        123280
      ]
    },
    {
      "parameters": {
        "content": "## 🟣 BLOCO 2 — Deduplicação\nVerifica se fatura já foi registrada.\nQuery: `hash_dedup LIKE 'fat_{id}_%'`.\n↳ Já registrada → OUT - Já Registrada (ALREADY_REGISTERED)\n↳ Nova → BLOCO 3",
        "height": 280,
        "width": 640,
        "color": 6
