    {
      "parameters": {
        "jsCode": "try {\n// Desempacotar wrapper { query: {...} } do toolWorkflow\nconst raw = $input.first().json;\nconst item = (raw.fatura_id !== undefined || raw.usuario_id) ? raw : (raw.query || raw);\n\nconst erros = [];\nif (!item.fatura_id && item.fatura_id !== 0) erros.push('fatura_id obrigatório');\nif (!item.usuario_id) erros.push('usuario_id obrigatório');\n\nreturn [{ json: {\n  inputs_validos: erros.length === 0,\n  erros,\n  fatura_id: item.fatura_id ? Number(item.fatura_id) : null,\n  usuario_id: item.usuario_id || ''\n}}];\n} catch (e) {\n  return [{ json: { inputs_validos: false, erros: ['CODE_ERROR: ' + (e.message || 'Erro desconhecido')], fatura_id: null, usuario_id: '' } }];\n}"
      },
