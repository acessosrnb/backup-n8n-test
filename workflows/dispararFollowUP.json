    {
      "parameters": {
        "jsCode": "// Obtém os tempos configurados para cada follow-up (em minutos)\nconst tempos = $('normalizarDados').first().json;\nconst tempoFollowUp1 = parseInt(tempos.tempo_followUp1, 10);\nconst tempoFollowUp2 = parseInt(tempos.tempo_followUp2, 10);\nconst tempoFollowUp3 = parseInt(tempos.tempo_followUp3, 10);\n\n// Captura o timestamp do nó 'Schedule Trigger'\nconst scheduleTrigger = $('executarFluxo').first().json;\nconst now = new Date(scheduleTrigger.timestamp);\n\n// Função utilitária para calcular diferença em minutos entre duas datas\nconst calcularDiferencaMinutos = (dataInicio, dataFim) => {\n  return Math.floor((dataFim - dataInicio) / (1000 * 60));\n};\n\n// Processa os clientes do nó 'Retorna os Pacientes'\nconst clientes = $('buscaClienteDoFollowUP').all();\nconst resultado = clientes.map((item) => {\n  const cliente = item.json;\n\n  // Validações iniciais (Nome e Número obrigatórios)\n  if (!cliente.nome || !cliente.numero) {\n    return {\n      ...cliente,\n      followup: 0\n    };\n  }\n\n  // Verifica se a última atividade está presente e válida\n  const ultimaAtividade = new Date(cliente[\"ultima_atividade\"]);\n  if (isNaN(ultimaAtividade.getTime())) {\n    return {\n      ...cliente,\n      followup: 0\n    };\n  }\n\n  // Calcula o tempo de inatividade em minutos\n  const inactivityMinutes = calcularDiferencaMinutos(ultimaAtividade, now);\n\n  // --- LÓGICA DE HIERARQUIA DE FOLLOW-UPS ---\n  \n  // 1. Se ainda não deu o tempo do primeiro follow-up\n  if (inactivityMinutes < tempoFollowUp1) {\n    return { ...cliente, followup: 0 };\n  }\n\n  // 2. Zona do Follow-up 1\n  if (inactivityMinutes >= tempoFollowUp1 && inactivityMinutes < tempoFollowUp2) {\n    // Verifica se JÁ FOI enviado (lê a coluna 'followup1' do banco)\n    if (cliente[\"followup1\"] === \"sim\") {\n      return { ...cliente, followup: 0 };\n    }\n    // Marca como sim para passar para o próximo node atualizar o banco\n    cliente[\"followup1\"] = \"sim\";\n    return { ...cliente, followup: 1 };\n  }\n\n  // 3. Zona do Follow-up 2\n  if (inactivityMinutes >= tempoFollowUp2 && inactivityMinutes < tempoFollowUp3) {\n    // Verifica se JÁ FOI enviado (lê a coluna 'followup2' do banco)\n    if (cliente[\"followup2\"] === \"sim\") {\n      return { ...cliente, followup: 0 };\n    }\n    // Marca como sim para passar para o próximo node atualizar o banco\n    cliente[\"followup2\"] = \"sim\";\n    return { ...cliente, followup: 2 };\n  }\n\n  // 4. Zona do Follow-up 3 (Final)\n  if (inactivityMinutes >= tempoFollowUp3) {\n    // Verifica se JÁ FOI enviado (lê a coluna 'followup3' do banco)\n    if (cliente[\"followup3\"] === \"sim\") {\n      return { ...cliente, followup: 0 };\n    }\n    // Marca como sim para passar para o próximo node atualizar o banco\n    cliente[\"followup3\"] = \"sim\";\n    return { ...cliente, followup: 3 };\n  }\n\n  // Caso nenhum follow-up seja aplicável (ex: erro de cálculo ou fora das faixas)\n  return { ...cliente, followup: 0 };\n});\n\n// Retorna o resultado final\nreturn resultado;"
      },
