    {
      "parameters": {
        "jsCode": "const phone = $input.first().json.phone || \"\";\n\n// remove tudo que não for número\nconst cleaned = phone.replace(/\\D/g, \"\");\n\n// adiciona 55 na frente\nconst formatted = `55${cleaned}`;\n\nreturn [\n  {\n    json: {\n      phone: formatted\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
