        "query": "DO $$\nDECLARE\n  v_mov INTEGER;\n  v_con INTEGER;\n  v_mem INTEGER;\n  v_itens INTEGER;\n  v_fat INTEGER;\nBEGIN\n  DELETE FROM movimentacoes;\n  GET DIAGNOSTICS v_mov = ROW_COUNT;\n\n  DELETE FROM contas;\n  GET DIAGNOSTICS v_con = ROW_COUNT;\n\n  DELETE FROM itens_fatura;\n  GET DIAGNOSTICS v_itens = ROW_COUNT;\n\n  DELETE FROM faturas;\n  GET DIAGNOSTICS v_fat = ROW_COUNT;\n\n  DELETE FROM n8n_chat_histories;\n  GET DIAGNOSTICS v_mem = ROW_COUNT;\n\n  RAISE NOTICE 'Limpeza: % movimentacoes, % contas, % itens_fatura, % faturas, % mensagens removidas',\n    v_mov, v_con, v_itens, v_fat, v_mem;\nEND;\n$$;",
