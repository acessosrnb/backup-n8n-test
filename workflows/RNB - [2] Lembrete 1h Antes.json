        "name": "Sheets - Eventos do Dia",
        "credentials": {
          "googleSheetsOAuth2Api": {
            "id": "zjkuvv93EujKZWDY",
            "name": "[Google Sheets] - rogerio@rnb"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst agora = new Date(); // UTC, OK — será comparado com eventDate também em UTC\nconst resultado = [];\n\nfor (const item of items) {\n  const d = item.json;\n\n  if (d.status_evento === 'Cancelado') continue;\n  if (d.lembrete_1h_enviado === 'sim') continue;\n  if (!d.telefone_lead || !d.hora_inicio || !d.data_de_inicio) continue;\n\n  // Constrói a data como horário de Brasília (UTC-3) explicitamente\n  const eventDate = new Date(d.data_de_inicio + 'T' + d.hora_inicio + ':00-03:00');\n\n  const diffMin = (eventDate.getTime() - agora.getTime()) / 60000;\n\n  if (diffMin >= 55 && diffMin <= 65) {\n    let tel = String(d.telefone_lead).replace(/\\D/g, '');\n    if (tel.length === 10 || tel.length === 11) tel = '55' + tel;\n\n    const nome = (d.nome_lead || '').split(' ')[0] || '';\n    const meetLink = d.link_reuniao || '';\n\n    const msg = `${nome}, nossa reunião começa em 1 hora! ⏳\\n\\n⏰ ${d.hora_inicio}h${meetLink ? `\\n💻 ${meetLink}` : ''}\\n\\nTe espero lá!`;\n\n    resultado.push({ json: { number: tel, text: msg, id_agendamento: d.id_agendamento } });\n  }\n}\n\nreturn resultado.length > 0 ? resultado : [];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1744,
          224
        ],
