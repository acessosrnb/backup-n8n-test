    {
      "parameters": {
        "jsCode": "/**\n * ------- UTILIDADES -------\n */\n\nconst parseBrDate = (s) => {\n  if (!s) return null;\n  const [d, m, rest] = s.split('/');\n  const [y, time]    = rest.trim().split(' ');\n  const [hh, mm]     = time.split(':');\n  return `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}T${hh.padStart(2,'0')}:${mm.padStart(2,'0')}:00`;\n};\n\nconst cleanDateString = (dateStr) => {\n  if (!dateStr) return null;\n  dateStr = dateStr.replace(' ', 'T').replace(/Z$/, '').split('.')[0];\n  if (dateStr.split(':').length === 2) dateStr += ':00';\n  return dateStr;\n};\n\nconst addOneHour = (dateStr) => {\n  const [datePart, timePart] = dateStr.split('T');\n  let [hh, mm, ss] = timePart.split(':').map(Number);\n  hh = (hh + 1) % 24;\n  return `${datePart}T${String(hh).padStart(2,'0')}:${String(mm).padStart(2,'0')}:${String(ss).padStart(2,'0')}`;\n};\n\nconst getHourDifference = (startStr, finishStr) => {\n  const start = new Date(startStr);\n  const finish = new Date(finishStr);\n  return (finish - start) / (1000 * 60 * 60);\n};\n\nlet item = $input.item;\n\nlet dateStart  = item.json.data_inicio;\nlet dateFinish = item.json.data_final;\nlet dataAntiga = item.json.data_antiga;\n\nif (dateStart?.includes('/') && dateStart?.includes(' '))  dateStart  = parseBrDate(dateStart);\nif (dateFinish?.includes('/') && dateFinish?.includes(' ')) dateFinish = parseBrDate(dateFinish);\n\ndateStart  = cleanDateString(dateStart);\ndateFinish = cleanDateString(dateFinish);\ndataAntiga = cleanDateString(dataAntiga);\n\nif (dateStart && dateFinish) {\n  const diff = getHourDifference(dateStart, dateFinish);\n  if (diff !== 1) dateFinish = addOneHour(dateStart);\n}\n\nitem.json.data_inicio  = dateStart;\nitem.json.data_final = dateFinish;\nitem.json.data_antiga = dataAntiga;\n\nreturn item;\n"
      },
