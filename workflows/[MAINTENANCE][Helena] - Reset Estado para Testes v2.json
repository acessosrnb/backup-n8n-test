    {
      "parameters": {
        "jsCode": "const chatIdRaw = $json.chatId || '';\nconst numeroBase = chatIdRaw.replace(/@s\\.whatsapp\\.net$/i, '').trim();\n\nif (!numeroBase || numeroBase.length < 10 || !/^\\d+$/.test(numeroBase)) {\n  throw new Error('chatId inv\\u00e1lido: \"' + chatIdRaw + '\". Informe n\\u00famero completo (ex: 5518997913488 ou 5518997913488@s.whatsapp.net).');\n}\n\nconst suffixes = ['_buf', '_mem', '_last_reply', '_timeout'];\nconst keys = suffixes.map(s => numeroBase + s);\n\nreturn [{\n  json: {\n    projeto: $json.projeto,\n    usuario: $json.usuario,\n    chatIdOriginal: chatIdRaw,\n    chatIdNormalizado: numeroBase + '@s.whatsapp.net',\n    numeroBase,\n    confirm: $json.confirm,\n    clearRagIndex: $json.clearRagIndex,\n    confirmRag: $json.confirmRag,\n    pineconeHost: $json.pineconeHost,\n    targetKeys: keys,\n    suffixes,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
