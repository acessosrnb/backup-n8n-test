    {
      "parameters": {
        "jsCode": "const ctx = $('code_normalizar_chatid').item.json;\nconst nodes = ['redis_del_buf', 'redis_del_mem', 'redis_del_last_reply', 'redis_del_timeout'];\nconst suffixes = ctx.suffixes;\n\nconst resultados = nodes.map((nodeName, i) => {\n  const chave = ctx.numeroBase + suffixes[i];\n  try {\n    const item = $(nodeName).first();\n    if (item?.json?.error || item?.json?.errorMessage) {\n      return { chave, status: 'erro', detalhe: item.json.error || item.json.errorMessage };\n    }\n    return { chave, status: 'processada' };\n  } catch(e) {\n    return { chave, status: 'erro', detalhe: e.message };\n  }\n});\n\nconst processadas = resultados.filter(r => r.status === 'processada').map(r => r.chave);\nconst erros = resultados.filter(r => r.status === 'erro');\n\nreturn [{\n  json: {\n    ...ctx,\n    resultados,\n    chavesProcessadas: processadas,\n    chavesComErro: erros,\n    totalProcessadas: processadas.length,\n    totalErros: erros.length\n  }\n}];"
      },
