    {
      "parameters": {
        "jsCode": "const d = $('code_consolidar_deletes').item.json;\nlet ragStatus = 'preservado';\n\ntry {\n  const pc = $('http_pinecone_delete_all').first();\n  if (pc && !pc.json?.error && !pc.json?.errorMessage) ragStatus = 'limpo (index: helena)';\n} catch(e) {\n  // Pinecone branch n\\u00e3o executou\n}\n\nreturn [{\n  json: {\n    projeto: d.projeto,\n    usuario: d.usuario,\n    chatIdOriginal: d.chatIdOriginal,\n    chatIdNormalizado: d.chatIdNormalizado,\n    numeroBase: d.numeroBase,\n    modo: 'execute',\n    timestamp: d.timestamp,\n    chavesAlvo: d.targetKeys,\n    chavesProcessadas: d.chavesProcessadas,\n    chavesRemovidas: d.chavesProcessadas,\n    chavesComErro: d.chavesComErro,\n    pinecone: ragStatus,\n    confirmRecebido: d.confirm,\n    observacoes: [\n      d.totalProcessadas + '/' + d.targetKeys.length + ' chaves processadas com sucesso.',\n      d.totalErros > 0 ? d.totalErros + ' chave(s) com erro: ' + d.chavesComErro.map(e => e.chave).join(', ') : 'Nenhum erro.',\n      ragStatus.includes('limpo') ? '\\u00CDndice Pinecone helena limpo.' : '\\u00CDndice Pinecone preservado.',\n      'Estado limpo para testes.'\n    ]\n  }\n}];"
      },
