        "jsCode": "const d = $json;\nreturn [{\n  json: {\n    projeto: d.projeto,\n    usuario: d.usuario,\n    chatIdOriginal: d.chatIdOriginal,\n    chatIdNormalizado: d.chatIdNormalizado,\n    numeroBase: d.numeroBase,\n    modo: 'dry_run',\n    timestamp: d.timestamp,\n    chavesAlvo: d.targetKeys,\n    chavesProcessadas: [],\n    chavesRemovidas: [],\n    chavesComErro: [],\n    pinecone: d.clearRagIndex === 'true' ? 'seria limpo (requer CLEAR_HELENA_RAG)' : 'preservado',\n    confirmRecebido: d.confirm,\n    confirmNecessario: 'RESET_HELENA_TEST_STATE',\n    observacoes: [\n      'MODO DRY RUN \\u2014 nenhuma chave foi removida.',\n      'ChatId normalizado: ' + d.chatIdOriginal + ' \\u2192 ' + d.numeroBase,\n      'Para executar: altere confirm para RESET_HELENA_TEST_STATE',\n      d.clearRagIndex === 'true'\n        ? 'Pinecone seria limpo (confirmRag necess\\u00e1rio: CLEAR_HELENA_RAG)'\n        : 'Pinecone n\\u00e3o ser\\u00e1 tocado.'\n    ]\n  }\n}];"
