      "id": "629953ca-78c0-42aa-b786-4307f2bb8000",
      "name": "Agregar_Eventos",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        0,
        800
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "dd1",
              "name": "data",
              "value": "={{\n(() => {\n  const ev = $json.data;\n  const cfg = $('definir_agenda').first().json;\n  const intervalo = cfg.timeBetweenMeetingsMinutes;\n  const dayMap = {0:'DOM',1:'SEG',2:'TER',3:'QUA',4:'QUI',5:'SEX',6:'SAB'};\n  const pad = n => String(n).padStart(2,'0');\n\n  // FIX TIMEZONE: Forçar todas as operações em America/Sao_Paulo\n  // Usar offset -03:00 para criar datas consistentes\n  function spNow() {\n    // Gerar \"agora\" em SP: pegar UTC e subtrair 3h para ter horário SP\n    const utc = new Date();\n    return new Date(utc.getTime() - 3 * 60 * 60 * 1000);\n  }\n\n  function toSPDate(dateStr) {\n    // Converter qualquer dateTime ISO para timestamp absoluto\n    // Se já tem offset (-03:00), Date() interpreta corretamente\n    // Se não tem offset, assumir que é São Paulo e adicionar -03:00\n    if (dateStr && !dateStr.match(/[+-]\\d{2}:\\d{2}$/) && !dateStr.endsWith('Z')) {\n      dateStr = dateStr + '-03:00';\n    }\n    return new Date(dateStr);\n  }\n\n  function getSlot(date, t) {\n    const [h,m] = t.split(':').map(Number);\n    const d = new Date(date);\n    d.setHours(h,m,0,0);\n    return d;\n  }\n\n  function sameDay(a,b) {\n    return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();\n  }\n\n  const result = [];\n  const hoje = spNow();\n  hoje.setHours(0,0,0,0);\n\n  // FIX: Converter eventos para timestamps absolutos via toSPDate\n  const eventos = Array.isArray(ev)\n    ? ev.filter(e => e?.start?.dateTime && e?.end?.dateTime).map(e => ({\n        start: toSPDate(e.start.dateTime),\n        end: toSPDate(e.end.dateTime)\n      }))\n    : [];\n\n  for(let i=0; i<12*7; i++){\n    const d = new Date(hoje);\n    d.setDate(hoje.getDate()+i);\n    d.setHours(0,0,0,0);\n    const dia = dayMap[d.getDay()];\n    const c = cfg.schedule.find(s => s.day===dia);\n    if(!c || !c.available) continue;\n    const ini = getSlot(d, c.hours.after);\n    const fim = getSlot(d, c.hours.before);\n\n    // Filtrar eventos do mesmo dia (comparando em horário SP)\n    const evDia = eventos.filter(e => sameDay(e.start, d) || sameDay(e.end, d));\n\n    for(let s=new Date(ini); s<fim;) {\n      const sf = new Date(s.getTime()+intervalo*60000);\n      if(sf>fim) break;\n\n      // FIX: Comparar slots (horário SP) com eventos (convertidos para SP)\n      const conflito = evDia.some(e => s < e.end && sf > e.start);\n\n      if(!conflito) {\n        result.push({\n          data: s.toISOString().split('T')[0],\n          start: pad(s.getHours())+':'+pad(s.getMinutes()),\n          end: pad(sf.getHours())+':'+pad(sf.getMinutes())\n        });\n      }\n      s = sf;\n    }\n  }\n  return JSON.stringify(result);\n})()\n}}",
              "type": "array"
            }
          ]
        },
        "options": {}
      },
      "id": "401799ff-1dff-46a0-8363-69a86ff6edb3",
      "name": "definir_disponibilidade",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        224,
        800
      ]
    },
    {
      "parameters": {
        "jsCode": "const slots=items[0].json.data||[];\nconst agrup={};\nfor(const s of slots){if(!agrup[s.data])agrup[s.data]=[];agrup[s.data].push(s.start);}\nconst hoje=new Date();\n// FIX: Usar data SP para filtrar hoje\nconst spNow=new Date(hoje.getTime()-3*60*60*1000);\nconst hojeStr=spNow.toISOString().split('T')[0];\nconst dias=Object.keys(agrup).filter(d=>d!==hojeStr).sort();\nconst sel=[];\nconst ph=h=>{const[hh,mm]=h.split(':').map(Number);return{hh,mm};};\nfor(const dia of dias.slice(0,10)){\n  const ord=agrup[dia].sort();\n  const man=ord.filter(h=>{const{hh}=ph(h);return hh<12;});\n  const tar=ord.filter(h=>ph(h).hh>=13).slice(0,10);\n  const [y,mo,d]=dia.split('-');\n  [...man,...tar].forEach(h=>sel.push(`${d}/${mo} às ${h}`));\n}\nreturn [{json:{disponibilidade:sel.join(', ')}}];"
      },
