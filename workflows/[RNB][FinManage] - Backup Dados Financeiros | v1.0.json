    {
      "parameters": {
        "jsCode": "const agora = $now.setZone('America/Sao_Paulo');\nconst data = agora.toFormat('yyyy-MM-dd');\n\n// CONFIGURAR UMA VEZ:\n// 1. Crie a pasta FINMANAGE_BACKUPS no Google Drive\n// 2. Abra a pasta, copie o ID da URL (parte apos /folders/)\n// 3. Cole o ID abaixo substituindo o texto entre aspas\nconst ID_PASTA_FINMANAGE_BACKUPS = '14hpHwMgz0MSjtGxEdtdqhhhESOzgZthG';\n\nreturn [{\n  json: {\n    data_backup: data,\n    nome_pasta: data,\n    id_pasta_pai: ID_PASTA_FINMANAGE_BACKUPS,\n    arquivo_categorias: 'backup_categorias_' + data + '.json',\n    arquivo_faturas: 'backup_faturas_' + data + '.json',\n    arquivo_itens_fatura: 'backup_itens_fatura_' + data + '.json',\n    arquivo_mapeamentos: 'backup_mapeamento_categorias_' + data + '.json'\n  }\n}];"
      },
      "id": "de64a7c3-a815-4bc6-8703-da50b568839e",
      "name": "Define Metadados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        2240
      ]
    },
