    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst meta = $('Define Metadados').first().json;\nconst fileName = meta.arquivo_categorias;\nconst base64 = Buffer.from(JSON.stringify(rows, null, 2), 'utf-8').toString('base64');\nreturn [{\n  json: { fileName, totalRegistros: rows.length },\n  binary: {\n    data: {\n      data: base64,\n      mimeType: 'application/json',\n      fileName: fileName,\n      fileExtension: 'json'\n    }\n  }\n}];"
